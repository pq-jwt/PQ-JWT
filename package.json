{
  "name": "@pq-jwt/core",
  "version": "1.0.5",
  "description": "Post-quantum JWT library using NIST-standardized ML-DSA and SLH-DSA. Drop-in successor to RS256/ES256.",
  "type": "module",
  "main": "./src/index.mjs",
  "module": "./src/index.mjs",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs",
      "default": "./src/index.mjs"
    }
  },
  "keywords": [
    "jwt",
    "post-quantum",
    "ml-dsa",
    "dilithium",
    "sphincs",
    "slh-dsa",
    "authentication",
    "token",
    "pqc",
    "nist",
    "fips-204",
    "cryptography"
  ],
  "author": {
    "name": "Sachin Ruhil",
    "email": "sachinruhil11@gmail.com",
    "url": "https://github.com/ruhil6789"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.7.2",
    "@noble/post-quantum": "^0.6.1"
  },
  "files": [
    "src/index.mjs",
    "src/index.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "types": "./src/index.d.ts",
  "scripts": {
    "test": "node test/test.mjs",
    "test:ecosystem": "node test/ecosystem/run.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pq-jwt/PQ-JWT.git"
  },
  "bugs": {
    "url": "https://github.com/pq-jwt/PQ-JWT/issues"
  },
  "homepage": "https://github.com/pq-jwt/PQ-JWT#readme"
}

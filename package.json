    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "types": "./src/index.d.ts",
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ruhil6789/pq-jwt.git"
